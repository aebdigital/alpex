# Public site URL used for SEO metadata, sitemap, robots.txt and structured data.
NEXT_PUBLIC_SITE_URL=https://alpex.sk

# Contact form recipient. Form submissions are sent to this address.
CONTACT_FORM_RECIPIENT=servis@alpex.sk

# SMTP2GO API key from the SMTP2GO dashboard.
SMTP2GO_API_KEY=your-smtp2go-api-key

# Verified SMTP2GO sender identity, for example:
# SMTP2GO_SENDER="ALPEX Autoservis <noreply@alpex.sk>"
SMTP2GO_SENDER="ALPEX Autoservis <noreply@alpex.sk>"
